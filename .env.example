UNO_ENV=development
UNO_POSTGRES_DSN=postgresql://uno:uno_dev@localhost:5432/uno_operator
UNO_REDIS_URL=redis://localhost:6379/0
UNO_EVENT_BUS_BACKEND=memory
UNO_LOG_LEVEL=INFO
UNO_CONFIG_PATH=./config/default.yaml
UNO_MODEL_REGISTRY_PATH=./models/registry
UNO_REPLAY_STORAGE_PATH=./data/replays

# Vision (VLM) — perception AND action grounding. Both are OFF unless enabled.
# VLM_PERCEPTION=1 routes canvas/Electron perception through a vision model and
# turns on the VLM grounding provider (choose_color etc. on canvas games).
VLM_PERCEPTION=0
# Vision-capable model-runtime profile to invoke (e.g. local/ollama-vlm). The
# grounding provider reuses this same profile.
VLM_PROFILE_ID=mock/uno-assistant
VLM_MODEL_RUNTIME_URL=http://127.0.0.1:8111
VLM_TIMEOUT_S=30
# HTTP budget the orchestrator gives a perceive/ground call that runs the VLM.
# MUST stay above VLM_TIMEOUT_S (cold model loads take tens of seconds) or the
# orchestrator ReadTimeouts before the model answers. Defaults to VLM_TIMEOUT_S+90.
VLM_HTTP_TIMEOUT_SEC=120

# Learned zones (verification-aware click-point cache). Falls back to the file
# store when unset.
LEARNED_ZONE_PG_DSN=postgresql://uno:uno_dev@localhost:5432/uno_operator

